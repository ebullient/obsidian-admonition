{
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "baseUrl": ".",
        "inlineSourceMap": true,
        "inlineSources": true,
        "target": "ES2022",
        "module": "nodenext",
        "noImplicitAny": true,
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "importHelpers": true,
        "lib": ["dom", "es5", "scripthost", "es2019", "es2022"]
    },
    "include": ["**/*.ts"]
}
