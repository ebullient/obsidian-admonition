{
  "name": "obsidian-admonition",
  "version": "12.0.5",
  "description": "Enhanced callouts for Obsidian.md",
  "main": "main.js",
  "scripts": {
    "gen-icons": "node icons/fas/_gen.js && node icons/far/_gen.js && node icons/fab/_gen.js && node icons/fa-names/_gen.js && node icons/octicons/_gen.js",
    "dev": "node ./esbuild.config.mjs",
    "build": "node ./esbuild.config.mjs production",
    "eslint": "npx eslint",
    "fix": "npx @biomejs/biome check --write ./src",
    "format": "npx @biomejs/biome format ./src",
    "lint": "npx @biomejs/biome lint ./src",
    "prebuild": "npx @biomejs/biome check ./src",
    "preversion": "npm run build",
    "version": "auto-changelog -p",
    "brat-notes": "run() { auto-changelog --stdout --hide-credit --hide-empty-releases --template .github/changelog.hbs -v $1 --starting-version $1 > release-notes.md; }; run"
  },
  "auto-changelog": {
    "backfillLimit": false,
    "commitLimit": false,
    "ignoreCommitPattern": "(🔖|🔨|🧹|changelog|release|Update README).*",
    "replaceText": {
      "([;.,] [rR]esolves) #\\d+\\.?\\s*$": "$1",
      "([;.,] [Ff]ixes) #\\d+\\.?\\s*$": "$1"
    }
  },
  "keywords": [],
  "author": "ebullient",
  "license": "MIT",
  "devDependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@popperjs/core": "^2.11.8",
    "@biomejs/biome": "2.4.16",
    "@primer/octicons": "^19.27.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/parser": "^8.60.0",
    "auto-changelog": "^2.5.0",
    "esbuild": "^0.28.1",
    "esbuild-sass-plugin": "^3.3.1",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "sass-embedded": "^1.100.0",
    "monkey-around": "^3.0.0",
    "obsidian": "^1.13.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  }
}
